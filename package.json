{
    "name": "mplp-protocol",
    "version": "1.0.0-rc.1",
    "private": true,
    "description": "MPLP Protocol v1.0 - vendor-neutral, protocol-first repository",
    "license": "Apache-2.0",
    "scripts": {
        "lint": "echo \"TODO: lint\"",
        "build": "pnpm -r build",
        "test": "pnpm -r test",
        "test:runtime": "pnpm --filter @mplp/reference-runtime test",
        "test:integration": "pnpm --filter @mplp/integration-* test",
        "test:sdk": "vitest run packages/sdk-ts/tests",
        "runtime:dump:single-agent": "ts-node scripts/dump-runtime-single-agent.ts",
        "test:runtime-compat:py": "python -m pytest packages/sdk-py/tests/cross_language/test_runtime_from_ts.py -v",
        "test:runtime-compat:compare": "ts-node scripts/compare-runtime-json.ts",
        "test:runtime-compat": "pnpm runtime:dump:single-agent && pnpm test:runtime-compat:py && pnpm test:runtime-compat:compare && vitest run tests/runtime-compat",
        "test:golden": "ts-node --transpile-only tests/golden/harness/ts/golden-runner.ts"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "@types/js-yaml": "^4.0.9",
        "ajv": "^8.12.0",
        "ajv-formats": "^2.1.1",
        "js-yaml": "^4.1.0",
        "json-schema-to-typescript": "^13.1.1",
        "ts-node": "^10.9.1",
        "typescript": "^5.3.2",
        "vitest": "^1.0.0"
    }
}