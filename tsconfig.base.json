        "packages/sdk-ts/src/core/index.ts"
      ],
      "@mplp/core/*": [
        "packages/sdk-ts/src/core/*"
      ],
      "@mplp/coordination": [
        "packages/sdk-ts/src/coordination/index.ts"
      ],
      "@mplp/coordination/*": [
        "packages/sdk-ts/src/coordination/*"
      ],
      "@mplp/runtime-minimal": [
        "packages/sdk-ts/src/runtime-minimal/index.ts"
      ],
      "@mplp/runtime-minimal/*": [
        "packages/sdk-ts/src/runtime-minimal/*"
      ],
      "@mplp/schema": [
        "packages/sdk-ts/src/schema/index.ts"
      ],
      "@mplp/schema/*": [
        "packages/sdk-ts/src/schema/*"
      ],
      "@mplp/modules": [
        "packages/sdk-ts/src/modules/index.ts"
      ],
      "@mplp/modules/*": [
        "packages/sdk-ts/src/modules/*"
      ],
      "@mplp/integration-llm-http": [
        "packages/sdk-ts/src/integration/llm-http/index.ts"
      ],
      "@mplp/integration-llm-http/*": [
        "packages/sdk-ts/src/integration/llm-http/*"
      ],
      "@mplp/integration-storage-fs": [
        "packages/sdk-ts/src/integration/storage-fs/index.ts"
      ],
      "@mplp/integration-storage-fs/*": [
        "packages/sdk-ts/src/integration/storage-fs/*"
      ],
      "@mplp/integration-storage-kv": [
        "packages/sdk-ts/src/integration/storage-kv/index.ts"
      ],
      "@mplp/integration-storage-kv/*": [
        "packages/sdk-ts/src/integration/storage-kv/*"
      ],
      "@mplp/integration-tools-generic": [
        "packages/sdk-ts/src/integration/tools-generic/index.ts"
      ],
      "@mplp/integration-tools-generic/*": [
        "packages/sdk-ts/src/integration/tools-generic/*"
      ],
      "@mplp/devtools": [
        "packages/sdk-ts/src/devtools/index.ts"
      ],
      "@mplp/devtools/*": [
        "packages/sdk-ts/src/devtools/*"
