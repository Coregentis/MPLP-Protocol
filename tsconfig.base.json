{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "baseUrl": ".",
        "paths": {
            "@mplp/core-protocol": [
                "packages/core-protocol/src"
            ],
            "@mplp/coordination": [
                "packages/coordination/src"
            ],
            "@mplp/reference-runtime": [
                "packages/reference-runtime/src"
            ],
            "@mplp/integration-storage-fs": [
                "packages/integration/storage-fs/src"
            ]
        }
    }
}