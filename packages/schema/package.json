{
  "name": "@mplp/schema",
  "version": "1.0.2",
  "description": "MPLP Protocol v1.0 JSON Schemas - All protocol schema definitions",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/coregentis/MPLP-Protocol.git",
    "directory": "packages/schema"
  },
  "keywords": [
    "mplp",
    "schema",
    "json-schema",
