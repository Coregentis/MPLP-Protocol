{
  "name": "@mplp/core",
  "version": "1.0.2",
  "description": "L1 Core Protocol models and validators for MPLP Protocol v1.0",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npx vitest run",
    "generate:types": "ts-node ../../scripts/generate-types-from-schemas.ts"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "ts-node": "^10.9.1",
    "vitest": "^0.34.0",
    "json-schema-to-typescript": "^13.0.0"
  },
  "author": "邦士（北京）网络科技有限公司",
  "copyright": "© 2025 邦士（北京）网络科技有限公司",
  "mplp": {
    "protocolVersion": "1.0.0",
    "frozen": true,
    "governance": "MPGC",
    "layer": "L1"
  },
  "homepage": "https://github.com/coregentis/MPLP-Protocol",
  "bugs": {
    "url": "https://github.com/coregentis/MPLP-Protocol/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/coregentis/MPLP-Protocol.git",
    "directory": "packages/core"
  },
  "keywords": [
    "MPLP",
    "multi-agent",
    "protocol"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false
}
