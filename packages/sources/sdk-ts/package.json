{
  "name": "@mplp/sdk-ts",
  "private": true,
  "version": "1.0.7",
  "description": "Build-source workspace mirror for the published @mplp/sdk-ts facade package, including Kernel Duty exports (not a publish target).",
  "license": "Apache-2.0",
  "author": "Coregentis AI",
  "repository": {
    "type": "git",
    "url": "https://github.com/Coregentis/MPLP-Protocol.git"
  },
  "bugs": {
    "url": "https://github.com/Coregentis/MPLP-Protocol/issues"
  },
  "homepage": "https://www.mplp.io",
  "keywords": [
    "mplp",
    "multi-agent",
    "protocol",
    "ai agents",
    "lifecycle",
    "typescript",
    "sdk",
    "facade",
    "source-mirror",
    "agent-os",
    "agent-os-protocol"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "schemas/",
    "README.md",
    "LICENSE.txt",
    "CHANGELOG.md"
  ],
  "mplp": {
    "protocolVersion": "1.0.0",
    "frozen": true,
    "governance": "MPGC",
    "layer": "Build-Source",
    "packageClass": "SOURCE-MIRROR",
    "sourcePackage": true,
    "publishBlocked": true,
    "publishScope": "source-workspace",
    "targetNpmPackage": "@mplp/sdk-ts",
    "kernelDutyBaselineCarried": true
  },
  "scripts": {
    "build": "tsc",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {
    "@mplp/core": "^1.0.6",
    "@mplp/coordination": "^1.0.6",
    "@mplp/runtime-minimal": "^1.0.5",
    "@mplp/schema": "^1.0.6",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "ts-node": "^10.9.1",
    "json-schema-to-typescript": "^13.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./kernel-duties": {
      "require": "./dist/kernel-duties.js",
      "import": "./dist/kernel-duties.js",
      "types": "./dist/kernel-duties.d.ts"
    }
  },
  "sideEffects": false,
  "copyright": "© 2026 Bangshi Beijing Network Technology Limited Company"
}
