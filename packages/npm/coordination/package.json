{
  "name": "@mplp/coordination",
  "version": "1.0.6",
  "description": "Derived coordination helper package for MPLP v1.0.0. Exposes convenience coordination and governance contracts over protocol-aligned types.",
  "license": "Apache-2.0",
  "author": "Coregentis AI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE.txt"
  ],
  "homepage": "https://www.mplp.io/what-is-mplp",
  "repository": {
    "type": "git",
    "url": "https://github.com/Coregentis/MPLP-Protocol.git"
  },
  "bugs": {
    "url": "https://github.com/Coregentis/MPLP-Protocol/issues"
  },
  "keywords": [
    "mplp",
    "multi-agent",
    "lifecycle",
    "protocol",
    "coordination",
    "governance",
    "ai-agent-lifecycle"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mplp/core": "^1.0.6"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "mplp": {
    "protocolVersion": "1.0.0",
    "frozen": true,
    "governance": "MPGC",
    "layer": "L2",
    "packageClass": "PUBLIC",
    "publishSurface": true,
    "publishScope": "public-npm",
    "packageRole": "coordination-helper",
    "contractMode": "derived-protocol-helper"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "copyright": "© 2026 Bangshi Beijing Network Technology Limited Company"
}
