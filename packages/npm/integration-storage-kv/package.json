{
  "name": "@mplp/integration-storage-kv",
  "version": "1.0.5",
  "description": "Runtime-level key-value storage integration helper for MPLP v1.0.0. Not a direct protocol object mirror.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@mplp/core": "^1.0.2"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "mplp": {
    "protocolVersion": "1.0.0",
    "frozen": true,
    "governance": "MPGC",
    "layer": "L4",
    "packageClass": "PUBLIC",
    "publishSurface": true,
    "publishScope": "public-npm",
    "packageRole": "integration-helper",
    "contractMode": "convenience-runtime-alias"
  },
  "author": "Coregentis AI",
  "copyright": "© 2026 Bangshi Beijing Network Technology Limited Company",
  "license": "Apache-2.0",
  "homepage": "https://www.mplp.io/what-is-mplp",
  "bugs": {
    "url": "https://github.com/Coregentis/MPLP-Protocol/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Coregentis/MPLP-Protocol.git"
  },
  "keywords": [
    "mplp",
    "multi-agent",
    "protocol",
    "lifecycle",
    "integration-helper"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  }
}
