{
  "name": "@mplp/conformance",
  "version": "1.0.0",
  "description": "Public compatibility alias for MPLP conformance tooling under the preferred terminology. Re-exports the legacy @mplp/compliance surface.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Coregentis/MPLP-Protocol.git"
  },
  "keywords": [
    "mplp",
    "conformance",
    "validation",
    "testing",
    "golden-flows",
    "multi-agent",
    "protocol",
    "lifecycle",
    "conformance-tooling"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@mplp/compliance": "^1.0.4",
    "typescript": "^5.9.3"
  },
  "author": "Coregentis AI",
  "copyright": "© 2026 Bangshi Beijing Network Technology Limited Company",
  "mplp": {
    "protocolVersion": "1.0.0",
    "frozen": true,
    "governance": "MPGC",
    "packageClass": "PUBLIC",
    "publishSurface": true,
    "publishScope": "public-npm",
    "packageRole": "conformance-compatibility-alias",
    "contractMode": "convenience-runtime-alias",
    "legacyAliasOf": "@mplp/compliance"
  },
  "homepage": "https://www.mplp.io/what-is-mplp",
  "bugs": {
    "url": "https://github.com/Coregentis/MPLP-Protocol/issues"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json"
  }
}
