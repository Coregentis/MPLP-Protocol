{
  "name": "@mplp/schema",
  "version": "1.0.6",
  "description": "Direct schema/data mirror package for MPLP v1.0.0 JSON Schema definitions, validator helpers, and canonical Kernel Duty baseline.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Coregentis/MPLP-Protocol.git"
  },
  "keywords": [
    "mplp",
    "schema",
    "json-schema",
    "protocol",
    "validation",
    "multi-agent",
    "lifecycle",
    "ai-agent-lifecycle"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "schemas"
  ],
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "author": "Coregentis AI",
  "copyright": "© 2026 Bangshi Beijing Network Technology Limited Company",
  "mplp": {
    "protocolVersion": "1.0.0",
    "frozen": true,
    "governance": "MPGC",
    "packageClass": "PUBLIC",
    "publishSurface": true,
    "publishScope": "public-npm",
    "packageRole": "schema-data-mirror",
    "contractMode": "direct-schema-data-mirror",
    "kernelDutyBaselineCarried": true
  },
  "homepage": "https://www.mplp.io/what-is-mplp",
  "bugs": {
    "url": "https://github.com/Coregentis/MPLP-Protocol/issues"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./kernel-duties": {
      "require": "./dist/kernel-duties.js",
      "import": "./dist/kernel-duties.js",
      "types": "./dist/kernel-duties.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json"
  }
}
