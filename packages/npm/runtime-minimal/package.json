{
  "name": "@mplp/runtime-minimal",
  "version": "1.0.5",
  "description": "Public minimal runtime helper package for MPLP v1.0.0. Exposes runtime-level AEL/VSL/orchestrator artifacts, not protocol SSOT objects.",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@mplp/core": "^1.0.2",
    "@mplp/coordination": "^1.0.2",
    "@mplp/modules": "^1.0.2"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0"
  },
  "author": "Coregentis AI",
  "copyright": "© 2026 Bangshi Beijing Network Technology Limited Company",
  "mplp": {
    "protocolVersion": "1.0.0",
    "frozen": true,
    "governance": "MPGC",
    "layer": "L3",
    "packageClass": "PUBLIC",
    "publishSurface": true,
    "publishScope": "public-npm",
    "packageRole": "runtime-minimal",
    "contractMode": "convenience-runtime-alias",
    "kernelDutyBaselineCarried": false
  },
  "homepage": "https://www.mplp.io/what-is-mplp",
  "bugs": {
    "url": "https://github.com/Coregentis/MPLP-Protocol/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Coregentis/MPLP-Protocol.git"
  },
  "keywords": [
    "mplp",
    "multi-agent",
    "protocol",
    "lifecycle",
    "ai-agent-lifecycle"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "echo 'Publish-only workspace: run unit tests in packages/sources/ instead'"
  }
}
