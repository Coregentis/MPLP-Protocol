{
  "name": "@mplp/hello-world",
  "version": "1.1.0-beta",
  "description": "Hello World example for MPLP - Get started in 5 minutes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "example:basic": "ts-node src/examples/basic-usage.ts",
    "example:modules": "ts-node src/examples/module-access.ts",
    "example:config": "ts-node src/examples/custom-config.ts",
    "example:all": "npm run example:basic && npm run example:modules && npm run example:config",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mplp",
    "hello-world",
    "example",
    "tutorial",
    "getting-started"
  ],
  "author": "MPLP Team",
  "license": "MIT",
  "dependencies": {
    "mplp": "file:../../"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.3",
    "ts-node": "^10.9.2",
    "rimraf": "^5.0.7"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}

