# ========================================
# MPLP Public Release .gitignore
# ========================================
# This .gitignore is specifically configured for the public-release branch
# to exclude all private development content while preserving the core
# open source components.

# ========================================
# PRIVATE DEVELOPMENT CONTENT (EXCLUDED)
# ========================================

# AI Assistant and Development Methodologies
.augment/
.backup-configs/
.governance/
.husky/
.pctd/
.quality/

# CI/CD and Infrastructure
.circleci/
.github/workflows/
docker/
k8s/

# Historical Archives and Internal Documentation
Archived/
validation-results/

# Development Scripts (keep only essential build/test)
scripts/
!scripts/build.js
!scripts/test.js

# Internal Documentation and Reports
COMMIT-HISTORY-CLARIFICATION.md
GITHUB-RELEASE-NOTES.md
OPEN-SOURCE-READINESS-REPORT.md
OPEN-SOURCE-RELEASE-NOTES.md
QUALITY-REPORT.md
RELEASE-CHECKLIST.md

# Development Configuration
config/
cucumber.config.js
jest.schema-application.config.js

# ========================================
# STANDARD OPEN SOURCE EXCLUSIONS
# ========================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
*.tsbuildinfo

# Coverage reports
coverage/
*.lcov

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log

# Temporary folders
tmp/
temp/

# Database
*.sqlite
*.db

# Test artifacts
test-results/
playwright-report/

# GLFB methodology reports
glfb-pseudocode-report.txt
**/glfb-pseudocode-report.txt

# MPLP specific
schemas/compiled/
extensions/compiled/

# Backup files
*_backup.*
*.backup