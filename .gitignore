# =============================================================================
# MPLP Development Repository - .gitignore
# =============================================================================
# This .gitignore is used for the internal development repository
# It keeps all development tools and internal content
#
# Repository: https://github.com/Coregentis/MPLP-Protocol-Dev
# Version: 1.0.0
# Last Updated: 2025-10-19
# Strategy: Full development environment (exclude ONLY runtime files)
# =============================================================================

# =============================================================================
# RUNTIME GENERATED FILES - ALWAYS EXCLUDE
# =============================================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs (generated at runtime)
dist/
build/
*.tsbuildinfo
.npm
.eslintcache

# Coverage reports (generated by tests)
coverage/
*.lcov
.nyc_output

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Environment variables (sensitive)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.staging

# =============================================================================
# OPERATING SYSTEM FILES
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
ehthumbs.db
Thumbs.db
desktop.ini

# Linux
*~

# =============================================================================
# IDE TEMPORARY FILES
# =============================================================================

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-workspace
*.sublime-project

# =============================================================================
# LOGS AND TEMPORARY FILES
# =============================================================================

# Logs
logs/
*.log

# Temporary folders
tmp/
temp/
cache/
.cache/

# Database files (local development)
*.sqlite
*.db
*.sqlite3

# Test artifacts
test-results/
playwright-report/

# =============================================================================
# BUILD ARTIFACTS
# =============================================================================

# Compiled schemas and extensions
schemas/compiled/
extensions/compiled/

# Package archives
*.tgz
*.tar.gz

# Backup files
*_backup.*
*.backup

# =============================================================================
# SDK DEVELOPMENT ARTIFACTS
# =============================================================================

# SDK build outputs
sdk/node_modules/
sdk/dist/
sdk/packages/*/dist/
sdk/packages/*/node_modules/
sdk/coverage/

# =============================================================================
# NOTES
# =============================================================================
# This .gitignore is designed for the DEVELOPMENT repository.
# It ensures that:
# 1. All source code is tracked
# 2. All development tools and configurations are tracked
# 3. All internal documentation is tracked
# 4. All test suites are tracked
# 5. Only runtime-generated files are excluded
#
# For the public open source repository, use .gitignore.public
# =============================================================================
