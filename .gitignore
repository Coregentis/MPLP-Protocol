# =============================================================================
# MPLP Public Open Source Release - .gitignore
# =============================================================================
# This .gitignore is used for the public open source repository
# It filters out internal development content while keeping core functionality
#
# Repository: https://github.com/Coregentis/MPLP-Protocol
# Version: 3.0.0 - Open Source Release
# Last Updated: 2025-11-10
# Strategy: Keep necessary development configs, exclude internal documents
# =============================================================================

# =============================================================================
# STANDARD NODE.JS IGNORES
# =============================================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs (dist/ is INCLUDED for immediate user usage)
build/
*.tsbuildinfo
.npm
.eslintcache

# Coverage reports
coverage/
*.lcov
.nyc_output

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.staging

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log

# Temporary folders
tmp/
temp/
cache/
.cache/

# Database files
*.sqlite
*.db
*.sqlite3

# Test artifacts
test-results/
playwright-report/

# =============================================================================
# MPLP SPECIFIC - BUILD AND DISTRIBUTION
# =============================================================================

# Compiled schemas and extensions
schemas/compiled/
extensions/compiled/

# Build artifacts
*.tgz
*.tar.gz

# Backup files
*_backup.*
*.backup

# =============================================================================
# INTERNAL DEVELOPMENT CONTENT - EXCLUDE FROM OPEN SOURCE
# =============================================================================

# AI Assistant and Development Tools
.augment/
.cursor/
.husky/
.pctd/
.quality/
.backup-configs/

# Internal CI/CD Configuration
.circleci/

# Internal Configuration
config/
.gitignore.private

# Internal Governance
.governance/

# =============================================================================
# ROOT DIRECTORY - INTERNAL DOCUMENTS
# =============================================================================

# Internal Reports and Audits
*-REPORT.md
*-SUMMARY.md
*-AUDIT.md
AUGMENT-DOCUMENTATION-*.md
DOCS-CORRECTION-*.md
ROOT-DOCUMENTATION-*.md

# Branch Management Documentation
BRANCH-MANAGEMENT-*.md

# CI/CD and Quality Reports
CI-CD-*.md
QUALITY-REPORT.md
ci-diagnostic-report.json

# Open Source Release Planning (Internal)
OPEN-SOURCE-*.md
ROOT-FILES-AUDIT-*.md
DOCUMENTATION-REVIEW-*.md
PUBLIC-REPO-*.md

# npm Publishing Documentation (Internal)
NPM-*.md

# Dual Version Release Documentation (Internal)
/DUAL-VERSION-*.md

# Internal Governance and Policies
COMMIT-HISTORY-*.md
GOVERNANCE.md
PRIVACY.md
MAINTAINERS.md
RELEASE-CHECKLIST.md

# Chinese Planning Documents
V1.1.0-beta-*.md
*-文档分类整合规划.md

# =============================================================================
# ARCHIVED AND INTERNAL DEVELOPMENT FILES
# =============================================================================

# Archived directory - internal development files and methodologies
Archived/
Archived/**/*

# Development Archives
.archive/
.archive/**/*

# Temporary Studio and Workspaces
temp_studio/

# =============================================================================
# SCRIPTS - KEEP ONLY PUBLIC RELEASE SCRIPTS
# =============================================================================

# Internal development and fix scripts
scripts/Fix-*.ps1
scripts/add-*.js
scripts/check-*.js
scripts/ci-diagnostic.js
scripts/comprehensive-*.js
scripts/detailed-*.js
scripts/enhance-*.js
scripts/find-*.js
scripts/fix-*.js
scripts/fix-*.sh
scripts/generate-*.js
scripts/switch-*.js
scripts/update-*.js
scripts/validate-*.js
scripts/verify-*.js

# =============================================================================
# SDK DEVELOPMENT FILES
# =============================================================================

# SDK build artifacts (keep SDK source)
sdk/node_modules/
sdk/dist/
sdk/packages/*/dist/
sdk/packages/*/node_modules/
sdk/coverage/
sdk/test-cli.js

# =============================================================================
# DOCUMENTATION - INTERNAL ONLY
# =============================================================================

# Internal Documentation Directories
docs/L4-Intelligent-Agent-OPS-Refactor/
docs/api/
docs/others/
docs/quality-assurance/

# =============================================================================
# SECURITY - SENSITIVE INFORMATION
# =============================================================================

# Actual secrets and production keys
**/actual-secrets.*
**/production-keys.*
**/*secret*.json
**/*credential*.json
**/*password*.txt

# API keys and tokens
**/.env.production
**/.env.staging

# =============================================================================
# QUALITY ASSURANCE - INTERNAL ONLY
# =============================================================================

# Quality reports and audits
QUALITY-*.md
**/quality-report*.json
**/audit-*.json

# Performance benchmarks (internal)
**/performance-*.json
**/benchmark-*.json

# =============================================================================
# DEVELOPMENT WORKFLOW - INTERNAL ONLY
# =============================================================================

# Development planning and strategy
**/planning-*.md
**/roadmap-internal*.md
**/strategy-*.md
**/*methodology*.md
**/*analysis*.md
**/*executive-summary*.md

# Meeting notes and internal communications
**/meeting-notes*.md
**/internal-*.md

# =============================================================================
# EXAMPLES - KEEP CLEAN EXAMPLES ONLY
# =============================================================================

# Development and debugging examples
examples/emergency-fix.js
examples/final-quality-fix.js
examples/fix-quality-issues.js
examples/quality-fix-phase2.js
examples/*/dist/
examples/*/node_modules/

# =============================================================================
# NOTES
# =============================================================================
# This .gitignore is designed for the public open source repository.
# It ensures that:
# 1. Core functionality code (src/, dist/) is published
# 2. Development configurations (tsconfig.json, jest.config.js) are included
# 3. Tests (tests/) are included for transparency
# 4. Public documentation is available
# 5. Examples and SDK are included
# 6. Internal development content is excluded
# 7. Sensitive information is protected
# 8. Methodology and internal documents remain private
#
# Branch Strategy:
# - main/master: Internal development (includes all files)
# - public-release: Open source release (excludes internal files)
# =============================================================================
