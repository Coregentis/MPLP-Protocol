# MPLP npm发布忽略文件
# 只发布必要的文件到npm registry
# 基于SCTM+GLFB+ITCM+RBCT方法论

# ============================================
# 源代码（已编译到dist/）
# ============================================
src/
*.ts
!*.d.ts

# ============================================
# Source Maps和Declaration Maps（开发用，不发布）
# ============================================
*.map
*.js.map
*.d.ts.map

# ============================================
# 测试文件
# ============================================
tests/
__tests__/
*.test.ts
*.test.js
*.spec.ts
*.spec.js
test/
coverage/

# ============================================
# 配置文件
# ============================================
tsconfig.json
tsconfig.build.json
tsconfig.*.json
jest.config.js
jest.config.ts
.eslintrc.js
.eslintrc.json
.prettierrc
.prettierrc.json
.prettierrc.js
.editorconfig

# ============================================
# 开发工具
# ============================================
scripts/
.husky/
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ============================================
# 文档（保留README.md, LICENSE, CHANGELOG.md）
# 文档已整合到docs/目录，用户可从GitHub访问完整文档
# ============================================
docs/
*.md
!README.md
!CHANGELOG.md
!LICENSE.md

# ============================================
# 内部文件和目录
# ============================================
.augment/
Archived/
temp_studio/
config/
.governance/
backups/
release/
public-release/

# ============================================
# Git文件
# ============================================
.git/
.gitignore
.gitattributes
.gitignore.public
.gitmodules

# ============================================
# CI/CD配置
# ============================================
.circleci/
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml
Jenkinsfile

# ============================================
# 示例应用（用户可以从GitHub获取）
# ============================================
examples/

# ============================================
# SDK包（单独发布）
# ============================================
sdk/

# ============================================
# 临时文件
# ============================================
*.log
*.tmp
*.temp
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ============================================
# 备份文件
# ============================================
*.bak
*.backup
*.old

# ============================================
# 环境文件
# ============================================
.env
.env.*
!.env.example

# ============================================
# 依赖目录
# ============================================
node_modules/

# ============================================
# 构建临时文件
# ============================================
*.tsbuildinfo
.cache/
.temp/
.tmp/

# ============================================
# 其他开发文件
# ============================================
TODO.md
NOTES.md
DEVELOPMENT.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
ROADMAP.md
TROUBLESHOOTING.md
QUICK_START.md

# ============================================
# 报告和分析文件
# ============================================
*.report.md
*-report.md
*-analysis.md
*-review.md
*-plan.md
*-success.md

# ============================================
# 脚本文件
# ============================================
*.sh
*.bat
*.cmd
*.ps1

# ============================================
# 锁文件（保留package-lock.json）
# ============================================
yarn.lock
pnpm-lock.yaml

# ============================================
